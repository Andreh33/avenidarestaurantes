# Restaurantes Avenida — variables de entorno
# Copia este archivo como .env.local y rellena los valores.

# URL canónica del sitio (sin barra final). En producción: https://restaurantesavenida.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — envío del formulario de reservas (OPCIONAL).
# Si falta, el formulario degrada elegantemente a la vía WhatsApp (§12.3 del prompt maestro).
RESEND_API_KEY=

# Buzón que recibe las solicitudes de reserva del formulario.
RESERVAS_EMAIL_TO=info@restaurantesavenida.com
